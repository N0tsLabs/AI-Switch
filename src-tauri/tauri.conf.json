{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AI-Switch",
  "version": "0.1.0",
  "identifier": "com.ai-switch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Switch",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://github.com/你的用户名/ai-switch/releases/latest/download/latest.json"],
      "pubkey": "",
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
